{
  "compilerOptions": {
    "target": "ES2020",
    "module": "CommonJS",
    "lib": ["ES2020"],
    "outDir": "./dist",
    "rootDir": "./src",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "paths": {
      "pdf-form-editor-shared": ["../shared/types.ts"]
    }
  },
  "include": ["src", "tests"],
  "ts-node": {
    "paths": true
  }
}
